graph LR
    %% ============================================
    %% MODULE INTERACTION & SHARED DATA PATTERN
    %% ============================================

    subgraph MonolithDB["MONOLITH DATABASE<br/>(Current State)"]
        direction TB

        subgraph AuthModule["🔐 AUTH MODULE"]
            Users["USERS<br/>- user_id (PK)<br/>- email (UK)<br/>- role<br/>- password_hash"]
            Roles["ROLES<br/>- role_id<br/>- permissions"]
            Users -->|"has"| Roles
        end

        subgraph EventModule["📅 EVENT MODULE"]
            Events["EVENTS<br/>- event_id (PK)<br/>- organizer_id (FK)<br/>- title, location"]
            SeatMaps["SEAT_MAPS<br/>- seat_map_id<br/>- event_id (FK)<br/>- zone_name, price"]
            Seats["SEATS<br/>- seat_id<br/>- seat_map_id (FK)<br/>- status"]
            Events -->|"has many"| SeatMaps
            SeatMaps -->|"has many"| Seats
        end

        subgraph BookingModule["🎫 BOOKING MODULE"]
            Bookings["BOOKINGS<br/>- booking_id (PK)<br/>- user_id (FK)<br/>- event_id (FK)<br/>- status"]
            Tickets["TICKETS<br/>- ticket_id<br/>- booking_id (FK)<br/>- seat_id (FK)<br/>- ticket_code (UK)<br/>- qr_token (UK)"]
            Bookings -->|"generates"| Tickets
        end

        subgraph PaymentModule["💳 PAYMENT MODULE"]
            Payments["PAYMENTS<br/>- payment_id<br/>- booking_id (FK)<br/>- amount, status"]
            Refunds["REFUNDS<br/>- refund_id<br/>- payment_id (FK)"]
            Payments -->|"may have"| Refunds
        end

        subgraph CheckinModule["✅ CHECK-IN MODULE"]
            Checkins["CHECKINS<br/>- checkin_id<br/>- ticket_id (FK)<br/>- is_online<br/>- device_id"]
            OfflineQueue["OFFLINE_CHECKIN_QUEUE<br/>- queue_id<br/>- ticket_code<br/>- sync_status<br/>- device_id"]
            Tickets -->|"has many"| Checkins
            Tickets -.->|"pending sync"| OfflineQueue
        end

        subgraph NotificationModule["🔔 NOTIFICATION MODULE"]
            Notifications["NOTIFICATIONS<br/>- notification_id<br/>- user_id (FK)<br/>- type<br/>- is_read"]
        end

        subgraph StaffModule["👥 STAFF MODULE"]
            Staff["STAFF<br/>- staff_id<br/>- user_id (FK)"]
            Assignments["STAFF_ASSIGNMENTS<br/>- assignment_id<br/>- event_id (FK)<br/>- staff_id (FK)"]
            Staff -->|"has many"| Assignments
        end

        subgraph ReportingModule["📊 REPORTING MODULE"]
            AttendanceStats["ATTENDANCE_STATS<br/>- stats_id<br/>- event_id (FK)<br/>- total_tickets<br/>- total_checkins"]
        end

        %% Cross-module relationships
        Users -->|"creates"| Events
        Users -->|"makes"| Bookings
        Events -->|"has many"| Bookings
        Bookings -->|"requires"| Payments
        Users -->|"receives"| Notifications
        Users -->|"has staff record"| Staff
        Events -->|"assigns"| Assignments
        Events -->|"generates"| AttendanceStats
    end

    %% ============================================
    %% MICROSERVICE BOUNDARY ANALYSIS
    %% ============================================

    subgraph BoundaryAnalysis["SERVICE BOUNDARIES FOR MICROSERVICES"]
        direction TB

        subgraph AuthBoundary["AUTH SERVICE"]
            AuthOwned["Owned Tables:<br/>USERS, ROLES<br/><br/>Exported Data:<br/>- user_id<br/>- email<br/>- role"]
        end

        subgraph EventBoundary["EVENT SERVICE"]
            EventOwned["Owned Tables:<br/>EVENTS, SEAT_MAPS, SEATS<br/><br/>Owned by: organizer_id (USER)<br/>Consumed FK: organizer_id"]
        end

        subgraph BookingBoundary["BOOKING SERVICE"]
            BookingOwned["Owned Tables:<br/>BOOKINGS, TICKETS<br/><br/>Foreign Keys:<br/>- user_id → AUTH<br/>- event_id → EVENT<br/>- seat_id → EVENT"]
        end

        subgraph PaymentBoundary["PAYMENT SERVICE"]
            PaymentOwned["Owned Tables:<br/>PAYMENTS, REFUNDS<br/><br/>Foreign Keys:<br/>- booking_id → BOOKING"]
        end

        subgraph CheckinBoundary["CHECK-IN SERVICE"]
            CheckinOwned["Owned Tables:<br/>CHECKINS, OFFLINE_CHECKIN_QUEUE<br/><br/>Foreign Keys:<br/>- ticket_id → BOOKING<br/>- staff_id → AUTH<br/>- device_id (local)"]
        end

        subgraph NotificationBoundary["NOTIFICATION SERVICE"]
            NotifOwned["Owned Tables:<br/>NOTIFICATIONS<br/><br/>Consumer of events from:<br/>- Booking Service<br/>- Payment Service<br/>- Check-in Service"]
        end

        subgraph StaffBoundary["STAFF SERVICE"]
            StaffOwned["Owned Tables:<br/>STAFF, STAFF_ASSIGNMENTS<br/><br/>Foreign Keys:<br/>- user_id → AUTH<br/>- event_id → EVENT"]
        end

        subgraph ReportBoundary["REPORTING SERVICE"]
            ReportOwned["Owned Tables:<br/>ATTENDANCE_STATS<br/><br/>Reads from:<br/>- Event Service<br/>- Booking Service<br/>- Payment Service<br/>- Check-in Service"]
        end
    end

    %% ============================================
    %% DATA CONSISTENCY PATTERNS
    %% ============================================

    subgraph ConsistencyPatterns["DATA CONSISTENCY PATTERNS"]
        direction TB

        SyncUpdate["🔄 Synchronous Update<br/>When: Real-time critical<br/>Example: seat_id → ticket<br/>seat_id validation before booking"]

        AsyncEvent["📨 Async Event Publishing<br/>When: Eventual consistency OK<br/>Example: payment.success<br/>→ notification service"]

        ReadOnly["📖 Read-Only Reference<br/>When: Cache-friendly<br/>Example: user_id, organizer_id<br/>cached from AUTH service"]

        SyncUpdate -.-> AsyncEvent -.-> ReadOnly
    end

    %% ============================================
    %% OFFLINE CHECK-IN SPECIAL FLOW
    %% ============================================

    subgraph OfflineFlow["⚡ OFFLINE CHECK-IN FLOW"]
        direction TB

        Device["📱 Device<br/>Offline<br/>- ticket_code input<br/>- LocalDB store"]

        Queue["📥 Queue Manager<br/>offline_checkin_queue<br/>- Create pending record<br/>- Local validation only"]

        Online["🌐 Online Sync<br/>when network restored<br/>- Send batch to server<br/>- Validate full criteria"]

        Merge["🔀 Merge Logic<br/>- Check if already synced<br/>- Handle conflicts<br/>- Update sync_status"]

        Device -->|"sync_status:<br/>pending"| Queue -->|"batch sync<br/>API call"| Online -->|"result"| Merge
    end

    style AuthModule fill:#e1f5ff
    style EventModule fill:#f3e5f5
    style BookingModule fill:#fff3e0
    style PaymentModule fill:#e8f5e9
    style CheckinModule fill:#fce4ec
    style NotificationModule fill:#f1f8e9
    style StaffModule fill:#ede7f6
    style ReportingModule fill:#e0f2f1
    style AuthBoundary fill:#b3e5fc
    style EventBoundary fill:#e1bee7
    style BookingBoundary fill:#ffe0b2
    style PaymentBoundary fill:#c8e6c9
    style CheckinBoundary fill:#f8bbd0
    style NotificationBoundary fill:#dcedc8
    style StaffBoundary fill:#d1c4e9
    style ReportBoundary fill:#b2dfdb


